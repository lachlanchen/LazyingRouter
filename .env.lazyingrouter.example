# LazyingRouter local development defaults.
# Copy to `.env` for local runs. Do not commit real upstream API keys.

PORT=3218
SYSTEM_NAME=LazyingRouter
FOOTER_HTML=LazyingRouter routes user-issued API keys to authorized upstream model providers.
LOGO_URL=/logo.png
FRONTEND_BASE_URL=http://127.0.0.1:3218
SQLITE_PATH=./data/lazyingrouter.sqlite
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
MEMORY_CACHE_ENABLED=true
NODE_NAME=lazying-router-local
TZ=Asia/Hong_Kong

# Set strong secrets for persistent or production deployments.
# SESSION_SECRET=
# CRYPTO_SECRET=

# Optional: create a default token on first boot for private bootstrap only.
# GENERATE_DEFAULT_TOKEN=false

# Optional upstream keys for scripts/bootstrap-provider-channels.py.
# Prefer adding production channels in the admin UI so keys are encrypted and auditable.
# Never commit real keys.
# OPENAI_API_KEY=
# OPENAI_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-mini,gpt-4.1,o4-mini
# OPENROUTER_API_KEY=
# OPENROUTER_MODELS=openrouter/auto,anthropic/claude-sonnet-4.5,openai/gpt-5.1
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
# VENICE_API_KEY=
# VENICE_BASE_URL=https://api.venice.ai/api
# VENICE_MODELS=
# GRSAI_API_KEY=
# GRSAI_OPENAI_BASE_URL=
# GRSAI_BASE_URL=
# GRSAI_MODELS=
